# ════════════════════════════════════════════════════════════════
# AUTH
# ════════════════════════════════════════════════════════════════

### Login as super_admin
# Copy the token from the response and paste it into @token above
POST {{baseUrl}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@federation.ma",
  "password": "ChangeMe123!"
}

###

### Get current user (me)
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{token}}

###

### Create a federation_admin user
POST {{baseUrl}}/api/v1/auth/users
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "email": "fed.admin@federation.ma",
  "password": "Admin1234!",
  "role": "federation_admin"
}

###

### Create a scanner user
POST {{baseUrl}}/api/v1/auth/users
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "email": "scanner@federation.ma",
  "password": "Scanner1234!",
  "role": "scanner"
}


# ════════════════════════════════════════════════════════════════
# CLUBS
# ════════════════════════════════════════════════════════════════

### Create a club
### Create club with clubShort
POST {{baseUrl}}/api/v1/clubs
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name":      "Club Nautique Plage Rabat",
  "code":      "CNPRXXY",
  "clubShort": "PR",
  "region":    "Rabat-Salé-Kénitra",
  "city":      "Rabat",
  "disciplines": ["surfing", "paddling"]
}

###

### List all clubs
GET {{baseUrl}}/api/v1/clubs
Authorization: Bearer {{token}}

###

### Get club by ID
# Replace CLUB_ID with the id from the create response
GET {{baseUrl}}/api/v1/clubs/{{clubId}}
Authorization: Bearer {{token}}

###

### Update club status to active
PATCH {{baseUrl}}/api/v1/clubs/{{clubId}}/status
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "status": "active"
}


# ════════════════════════════════════════════════════════════════
# MEMBERS
# ════════════════════════════════════════════════════════════════

### Create a member
POST {{baseUrl}}/api/v1/members
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName":   "Youssef1",
  "lastName":    "Benali1",
  "dateOfBirth": "2004-03-10",
  "gender":      "male",
  "email":       "youssef.benali1@gmail.com",
  "phone":       "+2126000000024",
  "height":      180,
  "armSpan":     178,
  "weight":      70,
  "clubId":      "{{clubId}}"
}

###


POST {{baseUrl}}/api/v1/members
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName":   "Adam",
  "lastName":    "safih",
  "dateOfBirth": "2004-03-10",
  "gender":      "male",
  "email":       "youssef2@gmail.com",
  "cin":         "AB123456",
  "height":      180,
  "armSpan":     178,
  "weight":      70
}

### Create a second member
POST {{baseUrl}}/api/v1/members
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "firstName":   "Salma",
  "lastName":    "Benali1",
  "dateOfBirth": "2004-03-10",
  "gender":      "female",
   "cin":         "AB12345jj6",
  "email":       "salma.benali1@gmail.com",
  "phone":       "+212600024",
  "height":      150,
  "armSpan":     138,
  "weight":      80,
  "clubId":      "{{clubId}}"
}

###

### List all members
GET {{baseUrl}}/api/v1/members
Authorization: Bearer {{token}}

###

### List members with filters
GET {{baseUrl}}/api/v1/members?status=pending&discipline=surfing&page=1&limit=10
Authorization: Bearer {{token}}

###

### Get member by ID
# Replace MEMBER_ID with the id from the create response
GET {{baseUrl}}/api/v1/members/69d4eba9afd1c511550defff
Authorization: Bearer {{token}}

###

### Update member status to active
PATCH {{baseUrl}}/api/v1/members/69d4f428d30098314bad0bb6
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "status": "active"
}

###

### Update member level
PATCH {{baseUrl}}/api/v1/members/69d107910cf934dfabb4cc8a
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "level": "pro"
}

###

### Delete (suspend) a member
DELETE {{baseUrl}}/api/v1/members/69d107a80cf934dfabb4cc8f
Authorization: Bearer {{token}}


# ════════════════════════════════════════════════════════════════
# CARDS
# ════════════════════════════════════════════════════════════════

### Generate membership card
# Member must exist — replace MEMBER_ID
POST {{baseUrl}}/api/v1/cards/69d57348322213f7d09c01da/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "validFrom":  "2025-01-01",
  "validUntil": "2025-12-31"
}

###

### Get card for a member
GET {{baseUrl}}/api/v1/cards/69d57348322213f7d09c01da
Authorization: Bearer {{token}}

###



### Get card for a specific season
GET {{baseUrl}}/api/v1/cards/69d4eba9afd1c511550defff?season=2026
Authorization: Bearer {{token}}


# ════════════════════════════════════════════════════════════════
# VERIFICATION
# ════════════════════════════════════════════════════════════════

### Verify a QR token (public — no auth needed)
# Replace QR_TOKEN with the qrPayload value from the card response
GET {{baseUrl}}/api/v1/verify/{{qrToken}}
Authorization: Bearer {{token}}
###

### Log a scan (authenticated scanner)
POST {{baseUrl}}/api/v1/verify/scan
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "token": "{{qrToken}}",
  "location": "Competition entrance - Casablanca"
}
###
POST {{baseUrl}}/api/v1/verify/scan
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "token":    "{{qrToken}}",
  "location": "Competition entrance - Casablanca"
}


# ════════════════════════════════════════════════════════════════
# ERROR CASES — make sure these return the right status codes
# ════════════════════════════════════════════════════════════════

### Login with wrong password — expect 401
POST {{baseUrl}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@federation.ma",
  "password": "wrongpassword"
}

###

### Get non-existent member — expect 404
GET {{baseUrl}}/api/v1/members/000000000000000000000000
Authorization: Bearer {{token}}

###

### Create member with invalid email — expect 400
POST {{baseUrl}}/api/v1/members
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "firstName": "Test",
  "lastName": "User",
  "dateOfBirth": "1990-01-01",
  "gender": "male",
  "email": "not-an-email",
  "disciplines": ["surfing"],
  "level": "amateur"
}

###

### Access protected route without token — expect 401
GET {{baseUrl}}/api/v1/members

###

### Verify invalid QR token — expect 401
GET {{baseUrl}}/api/v1/verify/this.is.not.valid





